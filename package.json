{
  "name": "tweakphp-app",
  "description": "Tweak your PHP code",
  "private": true,
  "version": "0.12.0",
  "type": "module",
  "author": {
    "name": "Saeed Vaziry",
    "email": "mr.saeedvaziry@gmail.com"
  },
  "scripts": {
    "dev": "vite",
    "tauri:dev": "tauri dev",
    "build": "vue-tsc --noEmit && vite build",
    "tauri:build": "tauri build",
    "build:mac": "npm run build && tauri build --target universal-apple-darwin",
    "build:mac-intel": "npm run build && tauri build --target x86_64-apple-darwin",
    "build:mac-arm": "npm run build && tauri build --target aarch64-apple-darwin",
    "build:linux": "npm run build && tauri build --target x86_64-unknown-linux-gnu",
    "build:linux-arm": "npm run build && tauri build --target aarch64-unknown-linux-gnu",
    "build:win": "npm run build && tauri build --target x86_64-pc-windows-msvc",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "prettier --check ./",
    "lint:fix": "prettier --write ./"
  },
  "dependencies": {
    "@codingame/monaco-vscode-configuration-service-override": "~7.0.7",
    "@codingame/monaco-vscode-files-service-override": "~7.0.7",
